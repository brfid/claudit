/* LCARS (Star Trek TNG) Theme for AI Cost Tracker TUI */

/* ── Color palette ── */
/* Amber: #FF9900  Mauve: #CC6699  Periwinkle: #9999CC
   Peach: #FFCC99  Lavender: #CC99CC  Tan: #CC9966
   Blue:  #6688CC  Red: #CC6666  Pale: #FFCC99 */

Screen {
    background: #000000;
}

/* ── Top bar ── */

#top-bar {
    dock: top;
    height: 3;
    background: #000000;
    layout: horizontal;
}

#top-elbow {
    width: 12;
    height: 3;
    background: #CC6699;
    content-align: center middle;
    color: #000000;
    text-style: bold;
}

#top-bar-line {
    width: 1fr;
    height: 1;
    margin-top: 1;
    background: #CC6699;
}

#top-title {
    width: auto;
    padding: 0 2;
    margin-top: 1;
    height: 1;
    color: #FF9900;
    text-style: bold;
    background: #000000;
}

/* ── Bottom bar ── */

#bottom-bar {
    dock: bottom;
    height: 3;
    background: #000000;
    layout: horizontal;
}

#bottom-elbow {
    width: 12;
    height: 3;
    background: #9999CC;
}

#bottom-bar-line {
    width: 1fr;
    height: 1;
    margin-bottom: 1;
    background: #9999CC;
}

#bottom-status {
    width: auto;
    padding: 0 2;
    margin-bottom: 1;
    height: 1;
    color: #9999CC;
    background: #000000;
}

/* ── Sidebar nav ── */

#sidebar {
    dock: left;
    width: 14%;
    min-width: 12;
    max-width: 20;
    background: #000000;
    padding: 0;
}

.nav-button {
    width: 100%;
    height: 3;
    margin-bottom: 1;
    border: none;
    text-style: bold;
    color: #000000;
    background: #CC9966;
    text-align: center;
    content-align: center middle;
}

.nav-button:hover {
    background: #FF9900;
}

.nav-button.active {
    background: #FF9900;
}

.nav-button:focus {
    background: #FF9900;
}

/* Compact sidebar: 1-row buttons for short terminals */
#sidebar.compact .nav-button {
    height: 1;
    margin-bottom: 0;
    background: #000000;
    color: #CC9966;
}

#sidebar.compact .nav-button:hover,
#sidebar.compact .nav-button.active,
#sidebar.compact .nav-button:focus {
    background: #000000;
    color: #FF9900;
}

/* ── Main content ── */

#main-content {
    margin: 0 1;
    background: #000000;
}

/* ── Overview panel ── */

#overview-panel {
    layout: grid;
    grid-size: 3 2;
    grid-columns: 1fr 1fr 1fr;
    grid-rows: 1fr 1fr;
    grid-gutter: 1 1;
    padding: 1;
    height: 1fr;
}

.stat-box {
    width: 100%;
    height: 100%;
    min-height: 10;
    border: round #CC6699;
    padding: 0 1;
    background: #0a0a0a;
    layout: vertical;
    align: left middle;
}

.stat-box .stat-text {
    width: 100%;
    height: auto;
    layout: vertical;
    padding: 1 0 0 0;
}

.stat-box .stat-label {
    width: 100%;
    height: 1;
    color: #9999CC;
    text-style: bold;
    text-align: left;
    padding: 0;
}

.stat-box .stat-value {
    width: 100%;
    height: 1;
    color: #FF9900;
    text-style: bold;
    text-align: left;
    padding: 0;
}

.stat-box .stat-detail {
    width: 100%;
    height: 1;
    color: #CC9966;
    text-align: left;
    padding: 0;
}

.stat-box .stat-spark {
    width: 100%;
    height: auto;
    layout: vertical;
    padding: 1 0 0 0;
}

.stat-box .spark-caption {
    width: 100%;
    height: 1;
    color: #666699;
    text-style: italic;
    text-align: right;
    padding: 0;
}

.stat-box Sparkline {
    width: 100%;
    height: 2;
    margin: 0;
}

Sparkline {
    height: 3;
    margin: 0 1;
}

Sparkline > .sparkline--max-color {
    color: #FF9900;
}

Sparkline > .sparkline--min-color {
    color: #CC6699;
}

/* ── Chart panels ── */

.chart-panel {
    padding: 0;
    background: #000000;
}

.chart-panel PlotextPlot {
    height: 1fr;
    min-height: 16;
    background: #000000;
}

/* Two-panel stack used by the TOKENS tab: split top/bottom evenly so
   neither sub-chart starves. Each child .chart-panel keeps its own
   plotext sizing rules above. */
.chart-stack {
    layout: vertical;
    height: 1fr;
}

.chart-stack > .chart-panel {
    height: 1fr;
    min-height: 14;
}

.chart-title {
    dock: top;
    height: 1;
    color: #FF9900;
    text-style: bold;
    padding: 0 1;
    background: #000000;
}

.chart-subtitle {
    dock: top;
    height: 1;
    color: #9999CC;
    padding: 0 1;
    background: #000000;
}

/* ── OPS tab ── */

.ops-section-title {
    height: 1;
    color: #FF9900;
    text-style: bold;
    padding: 0 1;
}

.ops-section-line {
    height: 1;
    color: #9999CC;
    padding: 0 1;
}

.ops-kv-line {
    height: 1;
    color: #CC9966;
    padding: 0 1;
}

/* ── Bordered panels with LCARS curves ── */

.ops-panel {
    border: round #CC6699;
    padding: 0 1;
    background: #0a0a0a;
    height: auto;
    border-title-color: #FF9900;
    border-title-style: bold;
    border-subtitle-color: #9999CC;
}

.ops-panel-session {
    height: auto;
    min-height: 8;
    margin: 0 0 1 0;
    padding: 0 1;
}

.ops-stat-row {
    height: 3;
    width: 100%;
    margin: 0;
}

.ops-stat-cell {
    width: 1fr;
    height: 3;
    padding: 0 0 0 1;
    background: #0a0a0a;
    border-left: outer #CC6699;
}

.ops-stat-cell-alt {
    border-left: outer #9999CC;
}

.ops-stat-cell-accent {
    border-left: outer #FF9900;
}

.ops-stat-cell-label {
    height: 1;
    color: #9999CC;
    text-style: bold;
}

.ops-stat-cell-value {
    height: 1;
    color: #FF9900;
    text-style: bold;
}

.ops-stat-cell-detail {
    height: 1;
    color: #CC9966;
}

.ops-hourly-wrap {
    height: 4;
    width: 100%;
    border: round #CC6699;
    border-title-color: #FF9900;
    border-title-style: bold;
    border-subtitle-color: #9999CC;
    padding: 0 1;
    margin-top: 0;
}

.ops-hourly-spark {
    height: 1;
    width: 100%;
    layout: horizontal;
}

.hourly-cell {
    width: 1fr;
    height: 1;
    content-align: center middle;
    background: #050505;
}

.hourly-cell-mark {
    background: #15151f;
}

.ops-hourly-axis {
    height: 1;
    width: 100%;
    layout: horizontal;
}

.hourly-axis {
    width: 1fr;
    height: 1;
    content-align: center middle;
}

/* Fluid bar components */
.fluid-bar {
    width: 1fr;
    height: 1;
}

.bar-cap {
    width: auto;
    height: 1;
}

.ops-mix-model-bar {
    height: 1;
    width: 100%;
    margin-bottom: 0;
}

.ops-hourly-spark > .sparkline--max-color {
    color: #FF9900;
}

.ops-hourly-spark > .sparkline--min-color {
    color: #CC6699;
}

.ops-project-name {
    height: 1;
    color: #FFCC99;
    padding: 0 1;
}

.ops-project-bar {
    height: 1;
    padding: 0 1;
    margin-bottom: 1;
}

.ops-mix-bar {
    height: 1;
    padding: 0 1;
    margin-bottom: 1;
}

.ops-mix-legend {
    height: 1;
    padding: 0 1;
}

.ops-side-by-side {
    height: auto;
    width: 100%;
    margin: 0 0 1 0;
}

.ops-panel-half {
    width: 1fr;
    height: auto;
    min-height: 5;
    margin: 0 1 0 0;
}

.ops-panel-half:last-of-type {
    margin-right: 0;
}

.ops-panel-third {
    width: 1fr;
    height: auto;
    min-height: 5;
    margin: 0 1 0 0;
}

.ops-panel-third:last-of-type {
    margin-right: 0;
}

.ops-labeled-bar {
    height: 1;
    width: 100%;
    margin-bottom: 0;
}

.panel-row-label {
    width: auto;
    height: 1;
}

.panel-row-footer {
    width: 100%;
    height: 1;
    padding: 0 1;
}

.bar-cap-right {
    width: auto;
    height: 1;
}

.ops-panel-log {
    height: auto;
}

/* Fill remaining vertical space — used by CALLS bucket panel so it
   grows with the terminal instead of collapsing to content height. */
.ops-panel-fill {
    height: 1fr;
    min-height: 14;
}

/* CALLS tab: bucket histogram row.
   Wider label cell than the standard ops ranked-panel row so the
   bucket range, count, and share fit without crowding the bar. */
.calls-bucket-row {
    height: 1;
    width: 100%;
    margin-bottom: 0;
}

.calls-bucket-label {
    width: 38;
    height: 1;
}

.calls-bucket-suffix {
    width: auto;
    height: 1;
    padding: 0 0 0 1;
}

.ops-project-row {
    height: 1;
    color: #FFCC99;
    padding: 0 1;
}

.ops-log-header {
    height: 1;
    color: #9999CC;
    text-style: bold;
    padding: 0 1;
}

.ops-log-row {
    height: 1;
    color: #CC9966;
    padding: 0 1;
}

.ops-log-row-new {
    color: #FFCC99;
    text-style: bold;
}

.ops-log-row-subagent {
    color: #9999CC;
}

.ops-log-row-cont {
    color: #8a7b5c;
}

.ops-log-row-selected {
    background: #FF9900;
    color: #000000;
    text-style: bold;
}

.ops-log-row:hover {
    background: #333333;
}

/* ── Entry detail modal ── */

EntryDetailScreen {
    align: center middle;
}

#entry-detail-box {
    width: 80;
    height: auto;
    max-height: 80%;
    border: round #FF9900;
    background: #0a0a0a;
    padding: 1 2;
}

#entry-detail-body {
    color: #FFCC99;
    height: auto;
}

#help-box {
    width: 52;
    height: auto;
    border: round #9999CC;
    background: #0a0a0a;
    padding: 1 2;
}

#help-body {
    color: #FFCC99;
    height: auto;
}

